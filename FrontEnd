    h+=mkCard('Mês Mais Recente',_repUltMes||'—',fR$c(_repUlt.valor),(_repUltMes||'')+(': '+fmt(_repUlt.numPedidos)+' pedidos'),(_repDelta>=0?'▲ ':'▼ ')+fPct(Math.abs(_repDelta))+' vs mês ant.','',_repDelta<=0,'amber');
    // Situações breakdown do mês mais recente
    const _sitRep=_repUlt.sit||{};
