    const proxRups=[...mrpR].sort((a,b)=>a.data<b.data?-1:1).slice(0,8);
    const hoje=new Date().toISOString().slice(0,10);
    proxRups.forEach(r=>{
      const diasAte=Math.ceil((new Date(r.data)-new Date(hoje))/86400000);
