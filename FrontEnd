  h+=mkCard('Margem Comercial',fPct(margemPct),fR$c(margemAbs),'Meta: ≥ 12%','','',margemPct>=0.12,'blue');
  // Card Represados — igual ao Faturamento Captado, com barra de progresso e meta
  const _repMes=(DATA.pedidosRepresados&&DATA.pedidosRepresados.porMes)?DATA.pedidosRepresados.porMes[mesNome]:null;
