  h+=mkCard('Saving',fPct(fsMes.precoAntigo>0?(fsMes.saving||0)/fsMes.precoAntigo:0),fR$c(fsMes.saving||0),'Meta: ≥ 15%','','',fsMes.precoAntigo>0&&fsMes.saving/fsMes.precoAntigo>=0.15,'purple');
