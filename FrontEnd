  const secTitle=(icon,title,color)=>`<div style="display:flex;align-items:center;gap:8px;margin:6px 0 4px"><span style="font-size:11px;font-weight:700;color:${color};text-transform:uppercase;letter-spacing:.5px">${icon} ${title}</span><div style="flex:1;height:1px;background:${color}22"></div></div>`;

