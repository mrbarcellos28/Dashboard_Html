  ouro.forEach((c,i)=>{h+=`<div style="padding:5px 0;border-bottom:1px solid rgba(255,255,255,.03);display:flex;justify-content:space-between"><span style="font-size:11px;color:var(--t1);max-width:55%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${i+1}. ${c.nome}</span><div><span style="font-size:12px;color:var(--green);font-weight:700">${fPct(c.mPct)}</span><span style="font-size:10px;color:var(--t3);margin-left:6px">${fR$c(c.fat)}</span></div></div>`});
