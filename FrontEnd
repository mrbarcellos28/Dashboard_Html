  // MRP: PLANEJADO vs REALIZADO
  // ══════════════════════════════════════════════════════════════════════
  const mrp=DATA.mrp||{};const mrpPM=mrp.porMes||{};const SKUS_MRP=['PALLETS'];
  // Construir meses disponíveis no MRP
  const mrpMeses=sortMeses(Object.keys(mrpPM));
  // Cruzar com produção realizada por mês (BASE: caixasProd = total geral)
  // prodPlan por mês = soma de prodPlan de todos os SKUs
  const mrpResumo=mrpMeses.map(m=>{
    const skuData=mrpPM[m]||{};
    let prodPlan=0,saidaPlan=0,saldoMin=null;
    SKUS_MRP.forEach(s=>{const sd=skuData[s]||{};prodPlan+=sd.prodPlan||0;saidaPlan+=sd.saidaPlan||0;if(sd.saldoMin!==null&&sd.saldoMin!==undefined){saldoMin=saldoMin===null?sd.saldoMin:Math.min(saldoMin,sd.saldoMin);}});
    const prodReal=(pAll.find(p=>p.mes===m)||{}).caixasProd||0;
    const desvio=prodPlan>0?(prodReal-prodPlan)/prodPlan:null;
    return{mes:m,prodPlan,saidaPlan,saldoMin,prodReal,desvio};
  });

  h+=`<div style="margin-top:16px;padding:8px 0 4px;border-top:1px solid rgba(255,255,255,.06)"><div class="sec-tag" style="background:rgba(66,66,111,.15);color:#7c7cbf;border:1px solid rgba(66,66,111,.35);margin-bottom:10px">📊 MRP — PLANEJADO vs REALIZADO</div></div>`;

  // KPI cards: último mês com dados cruzados
  const lastMrp=mrpResumo.filter(r=>r.prodReal>0).slice(-1)[0]||mrpResumo.slice(-1)[0]||null;
  h+=`<div class="card-grid" style="grid-template-columns:1fr 1fr 1fr 1fr;margin-bottom:8px">`;
  if(lastMrp){
    const devPct=lastMrp.desvio!==null?lastMrp.desvio:null;
    h+=mkCard('Demanda Pallets',lastMrp.mes,fmt(lastMrp.prodPlan)+' un','Retorno plan.: '+fmt(lastMrp.saidaPlan),'','',true,'green');
    h+=mkCard('Realizado',devPct!==null?fPct(1+(devPct)):lastMrp.prodReal>0?'✓':'—',fmt(lastMrp.prodReal)+' cx',devPct!==null?(devPct>=0?'▲ +'+fPct(devPct)+' vs plan':'▼ '+fPct(devPct)+' vs plan'):'Sem realizado','','',devPct!==null&&devPct>=-0.05,'green');
    h+=mkCard('Saldo Mín MRP',lastMrp.saldoMin!==null?fmt(lastMrp.saldoMin):' —',' ','Menor saldo do período','','',lastMrp.saldoMin===null||lastMrp.saldoMin>=0,'green');
    // Eficiência média dos meses com dados
    const comDados=mrpResumo.filter(r=>r.prodReal>0&&r.prodPlan>0);const eficMed=comDados.length>0?comDados.reduce((a,r)=>a+r.prodReal/r.prodPlan,0)/comDados.length:null;
    h+=mkCard('Eficiência Média',eficMed!==null?fPct(eficMed):'—',comDados.length+' meses','Realizado ÷ Planejado','','',eficMed!==null&&eficMed>=0.95,'green');
  } else {
    h+=`<div style="grid-column:1/-1;text-align:center;color:var(--t3);padding:20px">Sem dados MRP disponíveis</div>`;
  }
  h+=`</div>`;

  // Tabela SKU × Mês: desvio planejado vs realizado (últimos 3 meses com plan)
  if(mrpMeses.length>0){
    const ultMeses=mrpMeses.slice(-4);
    h+=`<div class="chart-card" style="padding:12px 14px;margin-bottom:8px">`;
    h+=`<div style="font-size:13px;font-weight:700;color:#7c7cbf;margin-bottom:10px">📋 MRP Pallets — Demanda Planejada por Mês</div>`;
    h+=`<div style="overflow-x:auto"><table style="width:100%;font-size:14px;border-collapse:collapse">`;
    h+=`<thead><tr style="border-bottom:1px solid rgba(255,255,255,.1);color:var(--t3)"><th style="text-align:left;padding:6px 10px">SKU</th>`;
    ultMeses.forEach(m=>{h+=`<th style="text-align:right;padding:6px 10px">${m}<br><span style="font-weight:400;font-size:9px">Demanda | Retorno</span></th>`;});
    h+=`</tr></thead><tbody>`;
    SKUS_MRP.forEach(sku=>{
      h+=`<tr style="border-bottom:1px solid rgba(255,255,255,.04)"><td style="padding:6px 10px;font-weight:700;color:var(--t1);font-size:14px">${sku}</td>`;
      ultMeses.forEach(m=>{
        const sd=(mrpPM[m]||{})[sku]||{};const pp=sd.prodPlan||0;const sp=sd.saidaPlan||0;
        const sm=sd.saldoMin;const ok=sm===null||sm>=0;
        h+=`<td style="text-align:right;padding:6px 10px"><span style="color:${pp>0?'#4ade80':'var(--t3)'}">${fmt(pp)}</span><span style="color:var(--t3)"> | </span><span style="color:#94a3b8">${fmt(sp)}</span>${sm!==null&&sm<0?`<br><span style="color:var(--red);font-size:9px">saldo:${fmt(sm)}</span>`:''}</td>`;
      });
      h+=`</tr>`;
    });
    h+=`</tbody></table></div></div>`;

    // Gráfico planejado vs realizado (total)
    const mrpComReal=mrpResumo.filter(r=>r.prodReal>0||r.prodPlan>0);
    if(mrpComReal.length>=2){
      h+=`<div class="charts-row"><div class="chart-card"><div class="chart-title">📊 Produção: Planejado vs Realizado (cx)</div><canvas id="chMrpVsReal" class="ccv"></canvas></div><div class="chart-card"><div class="chart-title">📉 Desvio % (Realizado − Planejado)</div><canvas id="chMrpDesvio" class="ccv"></canvas></div></div>`;
    }
  }
  return h;
}

