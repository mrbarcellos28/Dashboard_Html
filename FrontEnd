    if(_sitAguard>0)   h+=`<div style="display:flex;justify-content:space-between"><span style="color:var(--amber)">⏳ Aguardando</span><span style="font-weight:700">${fR$c(_sitAguard)}</span></div>`;
    if(_sitPrev>0)     h+=`<div style="display:flex;justify-content:space-between"><span style="color:var(--blue)">📅 Previsto Hoje</span><span style="font-weight:700">${fR$c(_sitPrev)}</span></div>`;
    if(_sitPend>0)     h+=`<div style="display:flex;justify-content:space-between"><span style="color:var(--t2)">⏸ Pendente</span><span style="font-weight:700">${fR$c(_sitPend)}</span></div>`;
    if(!_sitAtrasado&&!_sitAguard&&!_sitPrev&&!_sitPend) h+=`<span style="color:var(--t3)">Sem dados</span>`;
    h+=`</div></div>`;
    // Evolução acumulada
    let _repAcum=0;const _repAcumVals=_repMeses.map(m=>{_repAcum+=_repPM[m].valor;return _repAcum;});
    h+=mkCard('Acumulado Represado','',fR$c(_repAcum),_repMeses.length+' meses com represamento','','',_repAcum===0,'amber');
    h+=`</div>`;
    // Gráfico barras represados por mês + linha acumulada
    if(_repMeses.length>0){
      h+=`<div class="charts-row">`;
      h+=`<div class="chart-card"><div class="chart-title">🔒 Valor Represado por Mês (R$)</div><canvas id="chRepMes" class="ccv"></canvas></div>`;
      h+=`<div class="chart-card"><div class="chart-title">📊 Faturamento Mensal no Período Represado</div><canvas id="chRepAcum" class="ccv"></canvas></div>`;
      h+=`</div>`;
    }
    h+=`</div>`;

    // ═══ ATIVAÇÃO DE CLIENTES ═══
    h+=renderClientActivation();
  } else {
    const mc=DATA.margemCliente;
    const cMeses=sortMeses(Object.keys(mc).filter(m=>mc[m][state.client]));
    let cFat=0,cCustos=0;cMeses.forEach(m=>{const d=mc[m][state.client];cFat+=d.faturamento;cCustos+=d.custos});
    const cMrg=cFat>0?cCustos/cFat:0;
    h+=`<div class="card-grid" style="grid-template-columns:1fr 1fr 1fr">`;
