          const intensity=hmMax>0?mv/hmMax:0;
          const bg=mv>0?`rgba(167,139,250,${(intensity*0.6+0.05).toFixed(2)})`:'transparent';
          h+=`<td style="text-align:right;padding:3px 6px;background:${bg};border-radius:3px;color:${mv>0?'var(--t1)':'var(--t3)'}">${mv>0?fR$c(mv):'—'}</td>`;
        });
        h+=`<td style="text-align:right;padding:3px 6px;font-weight:600;color:var(--purple)">${fR$c(v.totalRs)}</td>`;
        h+=`</tr>`;
      });
      h+=`</tbody></table></div></div>`;
    }
  } else {
    h+=`<div class="chart-card" style="padding:16px;text-align:center;color:var(--t3)">Sem dados de vendedores disponíveis</div>`;
  }

  return h;
}

// ═══ CHARTS ═══
function getCanvas(id){const el=document.getElementById(id);if(!el)return null;const dpr=window.devicePixelRatio||1;el.width=el.offsetWidth*dpr;el.height=el.offsetHeight*dpr;const ctx=el.getContext('2d');ctx.scale(dpr,dpr);return{ctx,w:el.offsetWidth,h:el.offsetHeight}}
function roundRect(ctx,x,y,w,h,r){if(h<0){y+=h;h=-h}if(w<0){x+=w;w=-w}r=Math.min(r,w/2,h/2);ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath()}

function drawBar(id,labels,vals,color,isRS){const c=getCanvas(id);if(!c)return;const{ctx,w,h}=c;const n=vals.length;if(!n)return;const mx=Math.max(...vals,1);const pad={t:22,b:30,l:10,r:10};const cw=(w-pad.l-pad.r)/n;const ch=h-pad.t-pad.b;ctx.font='9px DM Sans';ctx.textAlign='center';for(let i=0;i<n;i++){const bh=mx>0?(vals[i]/mx)*ch:0;const x=pad.l+i*cw;const y=pad.t+ch-bh;ctx.fillStyle=i===n-1?color:color+'99';const bw=Math.max(cw-6,4);const rx=x+(cw-bw)/2;roundRect(ctx,rx,y,bw,bh,3);ctx.fill();ctx.fillStyle='#9898b0';ctx.fillText(labels[i].split('/')[0],x+cw/2,h-pad.b+14);ctx.fillStyle='#eaeaf2';ctx.font='8px DM Sans';ctx.fillText(isRS?fR$c(vals[i]):fmt(vals[i],0),x+cw/2,y-4);ctx.font='9px DM Sans'}}
function drawLine(id,labels,vals,color,suffix){const c=getCanvas(id);if(!c)return;const{ctx,w,h}=c;const n=vals.length;if(!n)return;const mx=Math.max(...vals,1);const mn=Math.min(...vals,0);const pad={t:22,b:30,l:10,r:10};const cw=(w-pad.l-pad.r)/(n-1||1);const ch=h-pad.t-pad.b;const range=mx-mn||1;ctx.strokeStyle=color;ctx.lineWidth=2;ctx.lineJoin='round';ctx.beginPath();for(let i=0;i<n;i++){const x=pad.l+i*cw;const y=pad.t+ch-(vals[i]-mn)/range*ch;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)}ctx.stroke();const grd=ctx.createLinearGradient(0,pad.t,0,h-pad.b);grd.addColorStop(0,color+'30');grd.addColorStop(1,color+'05');ctx.lineTo(pad.l+(n-1)*cw,h-pad.b);ctx.lineTo(pad.l,h-pad.b);ctx.closePath();ctx.fillStyle=grd;ctx.fill();ctx.font='8px DM Sans';ctx.textAlign='center';for(let i=0;i<n;i++){const x=pad.l+i*cw;const y=pad.t+ch-(vals[i]-mn)/range*ch;ctx.fillStyle=color;ctx.beginPath();ctx.arc(x,y,3,0,Math.PI*2);ctx.fill();ctx.fillStyle='#9898b0';ctx.font='9px DM Sans';ctx.fillText(labels[i].split('/')[0],x,h-pad.b+14);ctx.fillStyle='#eaeaf2';ctx.font='8px DM Sans';ctx.fillText(fmt(vals[i],1)+(suffix||''),x,y-8)}}
function drawDualLine(id,labels,v1,c1,l1,v2,c2,l2,isRS){const c=getCanvas(id);if(!c)return;const{ctx,w,h}=c;const n=labels.length;if(!n)return;const all=[...v1,...v2];const mx=Math.max(...all,1);const pad={t:22,b:30,l:10,r:10};const cw=(w-pad.l-pad.r)/(n-1||1);const ch=h-pad.t-pad.b;function dl(vals,col){ctx.strokeStyle=col;ctx.lineWidth=2;ctx.lineJoin='round';ctx.beginPath();for(let i=0;i<n;i++){const x=pad.l+i*cw;const y=pad.t+ch-vals[i]/mx*ch;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)}ctx.stroke()}dl(v2,c2);dl(v1,c1);const grd=ctx.createLinearGradient(0,pad.t,0,h-pad.b);grd.addColorStop(0,c1+'25');grd.addColorStop(1,c1+'05');ctx.beginPath();for(let i=0;i<n;i++){const x=pad.l+i*cw;const y=pad.t+ch-v1[i]/mx*ch;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)}ctx.lineTo(pad.l+(n-1)*cw,h-pad.b);ctx.lineTo(pad.l,h-pad.b);ctx.closePath();ctx.fillStyle=grd;ctx.fill();ctx.font='8px DM Sans';ctx.textAlign='center';for(let i=0;i<n;i++){const x=pad.l+i*cw;ctx.fillStyle='#9898b0';ctx.fillText(labels[i].split('/')[0],x,h-pad.b+14);const y1=pad.t+ch-v1[i]/mx*ch;ctx.fillStyle='#eaeaf2';ctx.fillText(isRS?fR$c(v1[i]):fmt(v1[i],0),x,y1-8)}ctx.font='8px DM Sans';ctx.fillStyle=c1;ctx.fillText('● '+l1,w/2-40,12);ctx.fillStyle=c2;ctx.fillText('● '+l2,w/2+40,12)}
function drawWaterfall(id,items){const c=getCanvas(id);if(!c)return;const{ctx,w,h}=c;const n=items.length;if(!n)return;const pad={t:15,b:30,l:10,r:10};const cw=(w-pad.l-pad.r)/n;const ch=h-pad.t-pad.b;const allVals=items.map(x=>Math.abs(x.val));const mx=Math.max(...allVals,1);let running=0;ctx.font='9px DM Sans';ctx.textAlign='center';for(let i=0;i<n;i++){const item=items[i];const x=pad.l+i*cw;const bw=Math.max(cw-12,8);const rx=x+(cw-bw)/2;let top,barH;if(item.type==='total'){barH=Math.abs(item.val)/mx*ch;top=pad.t+ch-barH;running=item.val;ctx.fillStyle='#3b82f6'}else if(item.type==='result'){barH=Math.abs(item.val)/mx*ch;top=item.val>=0?pad.t+ch-barH:pad.t+ch;ctx.fillStyle=item.val>=0?'#22c55e':'#ef4444'}else{const oldR=running;running+=item.val;const topR=Math.max(oldR,running);barH=Math.abs(item.val)/mx*ch;top=pad.t+ch-topR/mx*ch;ctx.fillStyle='#ef4444'}roundRect(ctx,rx,top,bw,barH,3);ctx.fill();if(item.meta!==null){const metaH=Math.abs(item.meta)/mx*ch;const metaY=pad.t+ch-metaH;ctx.strokeStyle='rgba(255,255,255,.3)';ctx.lineWidth=1;ctx.setLineDash([3,3]);ctx.beginPath();ctx.moveTo(rx-2,metaY);ctx.lineTo(rx+bw+2,metaY);ctx.stroke();ctx.setLineDash([])}ctx.fillStyle='#eaeaf2';ctx.fillText(fR$c(Math.abs(item.val)),x+cw/2,top-5);ctx.fillStyle='#9898b0';ctx.fillText(item.label,x+cw/2,h-pad.b+14)}}
function drawStackedArea(id,labels,v1,c1,l1,v2,c2,l2){const c=getCanvas(id);if(!c)return;const{ctx,w,h}=c;const n=labels.length;if(!n)return;const sums=v1.map((v,i)=>v+(v2[i]||0));const mx=Math.max(...sums,1)*1.1;const pad={t:18,b:25,l:10,r:10};const cw=(w-pad.l-pad.r)/(n-1||1);const ch=h-pad.t-pad.b;function yPos(v){return pad.t+ch-v/mx*ch}ctx.beginPath();for(let i=0;i<n;i++){const x=pad.l+i*cw;i===0?ctx.moveTo(x,yPos(sums[i])):ctx.lineTo(x,yPos(sums[i]))}ctx.lineTo(pad.l+(n-1)*cw,yPos(0));ctx.lineTo(pad.l,yPos(0));ctx.closePath();ctx.fillStyle=c2+'30';ctx.fill();ctx.beginPath();for(let i=0;i<n;i++){const x=pad.l+i*cw;i===0?ctx.moveTo(x,yPos(v1[i])):ctx.lineTo(x,yPos(v1[i]))}ctx.lineTo(pad.l+(n-1)*cw,yPos(0));ctx.lineTo(pad.l,yPos(0));ctx.closePath();ctx.fillStyle=c1+'30';ctx.fill();ctx.strokeStyle=c1;ctx.lineWidth=1.5;ctx.beginPath();for(let i=0;i<n;i++){const x=pad.l+i*cw;i===0?ctx.moveTo(x,yPos(v1[i])):ctx.lineTo(x,yPos(v1[i]))}ctx.stroke();ctx.strokeStyle=c2;ctx.beginPath();for(let i=0;i<n;i++){const x=pad.l+i*cw;i===0?ctx.moveTo(x,yPos(sums[i])):ctx.lineTo(x,yPos(sums[i]))}ctx.stroke();ctx.font='8px DM Sans';ctx.textAlign='center';for(let i=0;i<n;i++){ctx.fillStyle='#9898b0';ctx.fillText(labels[i].split('/')[0],pad.l+i*cw,h-pad.b+13)}ctx.fillStyle=c1;ctx.fillText('● '+l1,w/2-40,10);ctx.fillStyle=c2;ctx.fillText('● '+l2,w/2+40,10)}

