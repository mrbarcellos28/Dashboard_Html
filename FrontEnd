function drawDiretoriaCharts(){
  const m=DATA.resumoMensal.filter(x=>x.margemPct>=-1&&x.margemPct<=2);const fs=DATA.freteSavingMensal||{};
  const selM=m.find(x=>x.mes===state.dirMes);if(!selM)return;const selFS=fs[state.dirMes]||{};
  drawWaterfall('chWaterfall',[{label:'Faturamento',val:selM.faturamento,type:'total',meta:null},{label:'Impostos',val:-selM.custos,type:'neg',meta:-selM.faturamento*0.12},{label:'Frete',val:-(selFS.precoRealizado||0),type:'neg',meta:-selM.faturamento*0.065},{label:'Margem',val:selM.faturamento-selM.custos-(selFS.precoRealizado||0),type:'result',meta:null}]);
  const allMeses=m.map(x=>x.mes);const impPct=allMeses.map(mm=>{const r=m.find(x=>x.mes===mm);return r&&r.faturamento>0?r.custos/r.faturamento*100:0});const frePct=allMeses.map(mm=>{const f=fs[mm];const r=m.find(x=>x.mes===mm);return f&&r&&r.faturamento>0?f.precoRealizado/r.faturamento*100:0});
  drawStackedArea('chEficiencia',allMeses,impPct,'#a78bfa','Impostos %',frePct,'#f97316','Frete %');

  // ── Entrada de Caixa ──
  drawEntradaDiaria();
  drawEntradaMensal();
}

function drawEntradaDiaria(){
  const c=getCanvas('chEntradaDiaria');if(!c)return;
  const{ctx,w,h}=c;
  const ec=DATA.entradaCaixa||{};const diario=ec.diario||{};
  const mesNum=MESES_ORD.indexOf(state.dirMes.split('/')[0])+1;
  const anoNum=parseInt(state.dirMes.split('/')[1]);
  const hoje=new Date();const hojeStr=hoje.toISOString().slice(0,10);
  // Coletar todos os dias do mês
  const diasNoMes=new Date(anoNum,mesNum,0).getDate();
  const dias=[],vals=[],isPassado=[];
  for(let d=1;d<=diasNoMes;d++){
    const dk=anoNum+'-'+String(mesNum).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    const v=diario[dk]||0;
    if(v>0||(dk<=hojeStr)){dias.push(d);vals.push(v);isPassado.push(dk<=hojeStr);}
  }
  if(!vals.length)return;
  const mx=Math.max(...vals,1);
  const pad={t:22,b:28,l:8,r:8};const cw=(w-pad.l-pad.r)/Math.max(dias.length,1);const ch=h-pad.t-pad.b;
  ctx.font='9px DM Sans';ctx.textAlign='center';
  // Linha de hoje
  const hojeIdx=dias.findIndex((_,i)=>!isPassado[i])-1;
  if(hojeIdx>=0){
    const hojeX=pad.l+(hojeIdx+0.5)*cw+cw/2;
    ctx.strokeStyle='rgba(255,255,255,.12)';ctx.lineWidth=1;ctx.setLineDash([3,3]);
    ctx.beginPath();ctx.moveTo(hojeX,pad.t);ctx.lineTo(hojeX,h-pad.b);ctx.stroke();ctx.setLineDash([]);
    ctx.fillStyle='rgba(255,255,255,.15)';ctx.font='7px DM Sans';ctx.fillText('hoje',hojeX,pad.t-2);
  }
  for(let i=0;i<dias.length;i++){
    const bh=vals[i]/mx*ch;const x=pad.l+i*cw;const y=pad.t+ch-bh;
    const bw=Math.max(cw-3,2);const rx=x+(cw-bw)/2;
    ctx.fillStyle=isPassado[i]?'#22c55e':'#22c55e44';
    roundRect(ctx,rx,y,bw,bh,2);ctx.fill();
    // Label do dia (a cada 5)
    if(dias[i]%5===0||dias[i]===1){ctx.fillStyle='#9898b0';ctx.font='8px DM Sans';ctx.fillText(dias[i],x+cw/2,h-pad.b+12);}
    // Valor acima da barra se > 0
    if(vals[i]>0){ctx.fillStyle=isPassado[i]?'#eaeaf2':'#9898b0';ctx.font='7px DM Sans';ctx.fillText(fR$c(vals[i]),x+cw/2,y-3);}
  }
  // Total acumulado (linha)
  let acum=0;const acumVals=[];const acumPassado=[];
  for(let i=0;i<vals.length;i++){if(isPassado[i]){acum+=vals[i];acumVals.push(acum);acumPassado.push(true);}else{acumVals.push(acum+(vals[i]));acumPassado.push(false);}}
  const mxAcum=Math.max(...acumVals,1);
  ctx.strokeStyle='#86efac';ctx.lineWidth=1.5;ctx.lineJoin='round';ctx.beginPath();
  for(let i=0;i<dias.length;i++){
    const x=pad.l+i*cw+cw/2;const y=pad.t+ch-(acumVals[i]/mxAcum)*ch*0.85;
    i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
  }
  ctx.stroke();
}

function drawEntradaMensal(){
  const c=getCanvas('chEntradaMensal');if(!c)return;
  const{ctx,w,h}=c;
  const ec=DATA.entradaCaixa||{};const mensal=ec.mensal||{};
  const anoNum=parseInt(state.dirMes.split('/')[1]);
  const hoje=new Date();const hojeStr=hoje.toISOString().slice(0,10);
  // Meses do ano selecionado
  const meses=MESES_ORD.map(m=>m+'/'+anoNum).filter(m=>mensal[m]!=null&&mensal[m]>0);
  if(!meses.length)return;
  const vals=meses.map(m=>mensal[m]||0);
  const mx=Math.max(...vals,1);
  const pad={t:22,b:28,l:8,r:8};const n=meses.length;const cw=(w-pad.l-pad.r)/n;const ch=h-pad.t-pad.b;
  ctx.font='9px DM Sans';ctx.textAlign='center';
  for(let i=0;i<n;i++){
    const bh=vals[i]/mx*ch;const x=pad.l+i*cw;const y=pad.t+ch-bh;
    const bw=Math.max(cw-6,4);const rx=x+(cw-bw)/2;
    const isSel=meses[i]===state.dirMes;
    // Meses passados = cheio, meses futuros = transparente
    const mesDate=new Date(anoNum,MESES_ORD.indexOf(meses[i].split('/')[0]),1);
    const isPast=mesDate<=hoje;
    ctx.fillStyle=isSel?'#22c55e':isPast?'#22c55e88':'#22c55e22';
    roundRect(ctx,rx,y,bw,bh,3);ctx.fill();
    if(isSel){ctx.strokeStyle='#22c55e';ctx.lineWidth=1.5;roundRect(ctx,rx,y,bw,bh,3);ctx.stroke();}
    ctx.fillStyle='#9898b0';ctx.font='8px DM Sans';ctx.fillText(meses[i].split('/')[0],x+cw/2,h-pad.b+12);
    ctx.fillStyle=isSel?'#eaeaf2':'#9898b0';ctx.font='7px DM Sans';ctx.fillText(fR$c(vals[i]),x+cw/2,y-4);
  }
}

function drawTabProgressCharts(){
  if(state.tab==='vendas'&&!state.client)drawProgressChart('chProgFat','vendas');
  if(state.tab==='logistica')drawProgressChart('chProgFrete','logistica');
  if(state.tab==='producao')drawProgressChart('chProgCx','producao');
}
function drawProgressChart(canvasId,type){
  const c=getCanvas(canvasId);if(!c)return;const{ctx,w,h}=c;
  const mesNome=getCurMonth();if(!mesNome)return;const mesNum=MESES_ORD.indexOf(mesNome.split('/')[0])+1;const anoNum=parseInt(mesNome.split('/')[1]);const diasNoMes=new Date(anoNum,mesNum,0).getDate();
  let days=[],vals=[],meta=0,color='#3b82f6';
  if(type==='vendas'){
    color='#3b82f6';meta=calcMetaMesDinamica(mesNome);let acum=0;
    // Usa vendasDiario (Base-faturamento NF idx12) — mesma fonte do card Faturamento Real
    Object.keys(DATA.vendasDiario).sort().forEach(k=>{
      const d=new Date(k);
      if(d.getMonth()+1===mesNum&&d.getFullYear()===anoNum){
        acum+=DATA.vendasDiario[k].fat;days.push(d.getDate());vals.push(acum);}
    });
  }
  else if(type==='logistica'){color='#a78bfa';const fatMap={};DATA.resumoMensal.forEach(m=>fatMap[m.mes]=m.faturamento);meta=(fatMap[mesNome]||1)*0.065;let acum=0;if(DATA.logisticaDiario){Object.keys(DATA.logisticaDiario).sort().forEach(k=>{const d=new Date(k);if(d.getMonth()+1===mesNum&&d.getFullYear()===anoNum){acum+=DATA.logisticaDiario[k].custo||0;days.push(d.getDate());vals.push(acum)}})}}
  else if(type==='producao'){color='#8B6239';const last=DATA.producao[DATA.producao.length-1];meta=last?last.metaCaixas:100000;if(last){vals=[last.caixasProd];days=[new Date().getDate()]}}
  if(!days.length)return;
  const pad={t:20,b:30,l:50,r:20};const cw=w-pad.l-pad.r;const ch=h-pad.t-pad.b;const mx=Math.max(meta,...vals)*1.15;
  const metaY=pad.t+ch-meta/mx*ch;ctx.strokeStyle='rgba(255,255,255,.2)';ctx.lineWidth=1;ctx.setLineDash([5,5]);ctx.beginPath();ctx.moveTo(pad.l,metaY);ctx.lineTo(w-pad.r,metaY);ctx.stroke();ctx.setLineDash([]);
  ctx.font='9px DM Sans';ctx.fillStyle='#9898b0';ctx.textAlign='left';ctx.fillText('Meta: '+(type==='logistica'?fPct(0.065):fR$c(meta)),pad.l,metaY-5);
  ctx.strokeStyle=color;ctx.lineWidth=2.5;ctx.lineJoin='round';ctx.beginPath();for(let i=0;i<days.length;i++){const x=pad.l+(days[i]/diasNoMes)*cw;const y=pad.t+ch-vals[i]/mx*ch;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)}ctx.stroke();
  const grd=ctx.createLinearGradient(0,pad.t,0,h-pad.b);grd.addColorStop(0,color+'25');grd.addColorStop(1,color+'05');const lastX=pad.l+(days[days.length-1]/diasNoMes)*cw;ctx.lineTo(lastX,pad.t+ch);ctx.lineTo(pad.l+(days[0]/diasNoMes)*cw,pad.t+ch);ctx.closePath();ctx.fillStyle=grd;ctx.fill();
  const ly=pad.t+ch-vals[vals.length-1]/mx*ch;ctx.fillStyle=color;ctx.beginPath();ctx.arc(lastX,ly,4,0,Math.PI*2);ctx.fill();ctx.fillStyle='#eaeaf2';ctx.font='10px DM Sans';ctx.textAlign='center';ctx.fillText(fR$c(vals[vals.length-1]),lastX,ly-10);
  ctx.font='8px DM Sans';ctx.fillStyle='#5c5c78';ctx.textAlign='center';for(let d=1;d<=diasNoMes;d+=5){ctx.fillText(d,pad.l+(d/diasNoMes)*cw,h-pad.b+14)}
}


function drawAcumVsMeta(id,labels,vals,metaVals){
  const c=getCanvas(id);if(!c)return;const{ctx,w,h}=c;const n=labels.length;if(!n)return;
  const meta40=metaVals[metaVals.length-1]||40000000;
  const mx=Math.max(...vals,...metaVals,1)*1.08;
  const pad={t:28,b:32,l:62,r:16};const cw=(w-pad.l-pad.r)/(n-1||1);const ch=h-pad.t-pad.b;
  ctx.font='8px DM Sans';ctx.textAlign='right';ctx.fillStyle='#5c5c78';
  const steps=4;for(let s=0;s<=steps;s++){const v=mx*s/steps;const y=pad.t+ch-(v/mx)*ch;ctx.fillText(fR$c(v),pad.l-4,y+3);ctx.strokeStyle='rgba(255,255,255,.04)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(w-pad.r,y);ctx.stroke();}
  ctx.strokeStyle='rgba(255,255,255,.18)';ctx.lineWidth=1;ctx.setLineDash([5,4]);ctx.beginPath();const metaFinalY=pad.t+ch-(meta40/mx)*ch;ctx.moveTo(pad.l,metaFinalY);ctx.lineTo(w-pad.r,metaFinalY);ctx.stroke();ctx.setLineDash([]);
  ctx.fillStyle='rgba(255,255,255,.22)';ctx.font='8px DM Sans';ctx.textAlign='right';ctx.fillText('Meta R$40M',w-pad.r-2,metaFinalY-4);
  ctx.strokeStyle='rgba(255,255,255,.12)';ctx.lineWidth=1.5;ctx.lineJoin='round';ctx.beginPath();metaVals.forEach((v,i)=>{const x=pad.l+i*cw;const y=pad.t+ch-(v/mx)*ch;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)});ctx.stroke();
  const lastVal=vals[vals.length-1];const isOk=lastVal>=metaVals[vals.length-1];const lc=isOk?'#22c55e':'#ef4444';
  ctx.strokeStyle=lc;ctx.lineWidth=2.5;ctx.lineJoin='round';ctx.beginPath();vals.forEach((v,i)=>{const x=pad.l+i*cw;const y=pad.t+ch-(v/mx)*ch;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)});ctx.stroke();
  const grd=ctx.createLinearGradient(0,pad.t,0,h-pad.b);grd.addColorStop(0,lc+'22');grd.addColorStop(1,lc+'03');ctx.beginPath();vals.forEach((v,i)=>{const x=pad.l+i*cw;const y=pad.t+ch-(v/mx)*ch;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)});ctx.lineTo(pad.l+(n-1)*cw,pad.t+ch);ctx.lineTo(pad.l,pad.t+ch);ctx.closePath();ctx.fillStyle=grd;ctx.fill();
  ctx.font='8px DM Sans';ctx.textAlign='center';vals.forEach((v,i)=>{const x=pad.l+i*cw;const y=pad.t+ch-(v/mx)*ch;ctx.fillStyle=lc;ctx.beginPath();ctx.arc(x,y,3,0,Math.PI*2);ctx.fill();ctx.fillStyle='#9898b0';ctx.fillText(labels[i].split('/')[0],x,h-pad.b+13);if(i%2===0||i===n-1){ctx.fillStyle='#eaeaf2';ctx.font='7px DM Sans';ctx.fillText(fR$c(v),x,y-9);ctx.font='8px DM Sans';}});
  ctx.textAlign='left';ctx.fillStyle=lc;ctx.fillText('● Realizado',pad.l+2,14);ctx.fillStyle='rgba(255,255,255,.3)';ctx.fillText('● Meta',pad.l+70,14);
}

function drawBarDia(id,labels,vals,color,meta){
  const c=getCanvas(id);if(!c)return;const{ctx,w,h}=c;const n=labels.length;if(!n)return;
  const mx=Math.max(...vals,meta||0,1)*1.18;
  const pad={t:24,b:30,l:36,r:12};const cw=(w-pad.l-pad.r)/n;const ch=h-pad.t-pad.b;
  const hoje=new Date().getDate();
  // Grade horizontal
  for(let s=0;s<=4;s++){const y=pad.t+ch-(s/4)*ch;ctx.strokeStyle='rgba(255,255,255,.04)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(w-pad.r,y);ctx.stroke();}
  // Linha de meta diária
  if(meta>0){const my=pad.t+ch-(meta/mx)*ch;ctx.strokeStyle='rgba(255,255,255,.2)';ctx.lineWidth=1;ctx.setLineDash([4,4]);ctx.beginPath();ctx.moveTo(pad.l,my);ctx.lineTo(w-pad.r,my);ctx.stroke();ctx.setLineDash([]);ctx.fillStyle='rgba(255,255,255,.25)';ctx.font='7px DM Sans';ctx.textAlign='right';ctx.fillText('Meta: '+fmt(Math.round(meta)),w-pad.r-2,my-3);}
  // Barras
  const bw=Math.max(cw*0.7,2);
  for(let i=0;i<n;i++){
    const d=parseInt(labels[i]);const isPast=d<=hoje;
    const x=pad.l+i*cw+(cw-bw)/2;const bh=vals[i]/mx*ch;const y=pad.t+ch-bh;
    ctx.fillStyle=isPast?(vals[i]>=(meta*0.9)?color:color+'88'):color+'22';
    ctx.beginPath();ctx.roundRect?ctx.roundRect(x,y,bw,bh,2):ctx.rect(x,y,bw,bh);ctx.fill();
  }
  // Labels eixo X a cada 5 dias
  ctx.font='7px DM Sans';ctx.fillStyle='#5c5c78';ctx.textAlign='center';
  for(let i=0;i<n;i++){const d=parseInt(labels[i]);if(d===1||d%5===0){ctx.fillText(d,pad.l+i*cw+cw/2,h-pad.b+12);}}
}
initTabs();render();

// ═══ AUTO-REFRESH: atualiza dados a cada 5 minutos via google.script.run ═══
(function(){
  var REFRESH_MS=5*60*1000;
  var refreshTimer=null;
  var lastRefresh=Date.now();
  function atualizarDados(){
    if(typeof google==='undefined'||!google.script)return;
    try{
      google.script.run
        .withSuccessHandler(function(nd){
          if(!nd)return;
          Object.assign(DATA,nd);
          lastRefresh=Date.now();
          render();
          var clk=document.getElementById('clock');
          if(clk)clk.title='Atualizado: '+new Date().toLocaleTimeString('pt-BR');
        })
        .withFailureHandler(function(e){console.warn('Auto-refresh falhou:',e);})
        .coletarTodosDados();
    }catch(e){console.warn('Auto-refresh erro:',e);}
  }
  function agendarRefresh(){clearTimeout(refreshTimer);refreshTimer=setTimeout(function(){atualizarDados();agendarRefresh();},REFRESH_MS);}
  agendarRefresh();
  document.addEventListener('visibilitychange',function(){
    if(!document.hidden&&Date.now()-lastRefresh>REFRESH_MS){atualizarDados();agendarRefresh();}
  });
})();
</script>
