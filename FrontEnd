  }

  // Pallets section
  const sp=DATA.saldoPallets||{};const spR=sp.resumo||{};const ppM=DATA.palletsPorMes||{};const ppMeses=sortMeses(Object.keys(ppM));const lastPPM=ppMeses.length>0?ppM[ppMeses[ppMeses.length-1]]:{};
  h+=`<div style="margin-top:18px;padding:8px 0;border-top:1px solid rgba(255,255,255,.06)"><div class="sec-tag" style="background:rgba(168,85,247,.15);color:#c084fc;margin-bottom:10px">📦 GESTÃO DE PALLETS</div></div>`;
