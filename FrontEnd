function startCarousel(){state.carousel=true;state.carStart=Date.now();state.carCurrentInterval=getCarInterval(state.tab);document.getElementById('carBar').style.display='block';document.getElementById('btnCarousel').classList.add('on');document.getElementById('btnCarousel').textContent='⏸ Carrossel';carTick();startAutoScroll();scheduleNextTab()}
function scheduleNextTab(){clearTimeout(state.carTimer);state.carCurrentInterval=getCarInterval(state.tab);state.carStart=Date.now();state.carTimer=setTimeout(function(){if(!state.carousel)return;stopAutoScroll();var content=document.getElementById('content');if(content)content.scrollTop=0;var i=CAR_TABS.indexOf(state.tab);switchTab(CAR_TABS[(i+1)%CAR_TABS.length])},state.carCurrentInterval)}
