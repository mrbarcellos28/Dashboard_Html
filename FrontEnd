  h+=`<div style="margin-top:16px;padding:8px 0 4px;border-top:1px solid rgba(255,255,255,.06)"><div class="sec-tag" style="background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.2);margin-bottom:10px">⚠️ RUPTURA DE ESTOQUE PROJETADA (MRP)</div></div>`;
  const SKUS=['AT1','AT2','AT5','CT1','CT2','CT5'];
  const rupBySku={};mrpR.forEach(r=>{if(!rupBySku[r.sku])rupBySku[r.sku]=[];rupBySku[r.sku].push(r);});
  h+=`<div class="card-grid" style="grid-template-columns:repeat(6,1fr);margin-bottom:8px">`;
  SKUS.forEach(sku=>{
    const rups=rupBySku[sku]||[];const nRup=rups.length;const piorSaldo=nRup>0?Math.min(...rups.map(r=>r.saldo)):0;
    const proxRup=nRup>0?rups.sort((a,b)=>a.data<b.data?-1:1)[0]:null;
    const ok=nRup===0;
    h+=`<div class="card compact ${ok?'a-green':'a-red'}"><div class="card-label">${sku}</div><div style="font-size:22px;font-weight:800;color:${ok?'var(--green)':'var(--red)'}">${nRup===0?'✓':nRup+'x'}</div><div style="font-size:10px;color:var(--t3);margin-top:4px">${nRup===0?'Sem ruptura':'Pior: '+fmt(piorSaldo)}</div>${proxRup?`<div style="font-size:9px;color:var(--amber);margin-top:3px">1ª: ${proxRup.data.slice(5)}</div>`:''}</div>`;
