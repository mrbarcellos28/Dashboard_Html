    h+=`</div>`;
    if(cMeses.length>1)h+=`<div class="charts-row"><div class="chart-card"><div class="chart-title">Faturamento por Mês</div><canvas id="chCliFat" class="ccv"></canvas></div><div class="chart-card"><div class="chart-title">Margem %</div><canvas id="chCliMrg" class="ccv"></canvas></div></div>`;
  }
  return h;
}

// ═══ TABELA ATIVAÇÃO CLIENTES ═══
function renderClientActivation(){
  // Build client list from available data sources
  let clientList=[];
  const hoje=new Date();

  // Source 1: clientesAtivos from backend (preferred - has products)
  if(DATA.clientesAtivos&&DATA.clientesAtivos.clientes&&DATA.clientesAtivos.clientes.length>0){
    clientList=DATA.clientesAtivos.clientes.map(c=>({
      nome:c.nome, ultimaCompra:c.ultimaCompra, dias:c.diasSemCompra, status:c.status,
      valor:c.totalUltCompra||0, produtos:(c.produtos||[]).map(p=>p.sku).filter(Boolean).join(', ')
    }));
  }
  // Source 2: Fallback to clientes30d + ultimaCompraValor
  else if(DATA.clientes30d&&DATA.clientes30d.length>0){
    clientList=DATA.clientes30d.map(c=>{
      const d=c.ultimaCompra?new Date(c.ultimaCompra):null;
      const dias=d?Math.floor((hoje.getTime()-d.getTime())/86400000):999;
      let status='Ativo';
      if(dias>90)status='Inativo';else if(dias>60)status='Lead Perdido';else if(dias>30)status='Alerta';
      return{nome:c.nome,ultimaCompra:c.ultimaCompra||'—',dias:dias,status:status,
        valor:DATA.ultimaCompraValor[c.nome]||0,produtos:''}
    });
  }

  if(!clientList.length)return'';

  // Sort: most days first (urgent first)
  clientList.sort((a,b)=>b.dias-a.dias);

  // Count by category
  const urgente=clientList.filter(c=>c.dias>90).length;
  const alerta=clientList.filter(c=>c.dias>60&&c.dias<=90).length;
  const followup=clientList.filter(c=>c.dias>30&&c.dias<=60).length;
  const ativos=clientList.filter(c=>c.dias<=30).length;

  // Also use clientesSemCompra if available
  const csc=DATA.clientesSemCompra||{};

  let h='<div style="margin-top:14px;padding:8px 0;border-top:1px solid rgba(255,255,255,.06)"><div style="font-size:13px;font-weight:700;color:var(--blue);margin-bottom:10px">🔔 ATIVAÇÃO DE CLIENTES</div></div>';

  // Summary cards
  h+=`<div class="card-grid" style="grid-template-columns:1fr 1fr 1fr 1fr">`;
  h+=`<div class="card compact a-green"><div class="card-label">✅ Ativos (≤30d)</div><div class="card-abs" style="font-size:24px;color:var(--green)">${fmt(ativos)}</div></div>`;
  h+=`<div class="card compact a-blue"><div class="card-label">📞 Follow-up (31-60d)</div><div class="card-abs" style="font-size:24px;color:var(--blue)">${fmt(followup)}</div></div>`;
  h+=`<div class="card compact a-orange"><div class="card-label">⚠️ Alerta (61-90d)</div><div class="card-abs" style="font-size:24px;color:var(--amber)">${fmt(alerta)}</div></div>`;
  h+=`<div class="card compact a-red"><div class="card-label">🚨 Urgente (>90d)</div><div class="card-abs" style="font-size:24px;color:var(--red)">${fmt(urgente)}</div></div>`;
  h+=`</div>`;

  // Clientes sem compra por período
  if(csc.totalClientes>0){
    h+=`<div class="card-grid" style="grid-template-columns:1fr 1fr 1fr;margin-bottom:4px">`;
    h+=mkCardCompact('Sem compra >30 dias',fmt(csc.sem30d||0),'de '+fmt(csc.totalClientes)+' clientes','blue');
    h+=mkCardCompact('Sem compra >60 dias',fmt(csc.sem60d||0),'de '+fmt(csc.totalClientes)+' clientes','orange');
    h+=mkCardCompact('Sem compra >90 dias',fmt(csc.sem90d||0),'de '+fmt(csc.totalClientes)+' clientes','red');
    h+=`</div>`;
  }

  // Filter: only show clients that need attention (>30 days)
  const needsAttention=clientList.filter(c=>c.dias>30);
  if(!needsAttention.length) return h+'<div style="color:var(--t3);font-size:12px;padding:10px;text-align:center">Todos os clientes estão ativos (compras nos últimos 30 dias)</div>';

  // Table
  h+=`<div class="tbl-wrap"><div class="tbl-head"><span class="tbl-title">📋 Clientes que precisam de ativação</span><span class="tbl-count">${needsAttention.length} clientes</span></div>`;
  h+=`<div class="tbl-body"><table><thead><tr><th>Status</th><th>Cliente</th><th>Última Compra</th><th style="text-align:right">Valor R$</th><th>Produtos</th><th style="text-align:right">Dias</th></tr></thead><tbody>`;

  needsAttention.forEach(c=>{
    let statusCls='status-followup';let statusLabel='Follow-up';
    if(c.dias>90){statusCls='status-urgente';statusLabel='URGENTE'}
    else if(c.dias>60){statusCls='status-alerta';statusLabel='Alerta'}

    const dataFmt=c.ultimaCompra&&c.ultimaCompra!=='—'?c.ultimaCompra.split('-').reverse().join('/'):'—';
    const prods=c.produtos?(c.produtos.length>60?c.produtos.substring(0,60)+'…':c.produtos):'—';

    h+=`<tr><td><span class="${statusCls} status-tag">${statusLabel}</span></td><td style="color:var(--t1);font-weight:500;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${c.nome}</td><td>${dataFmt}</td><td style="text-align:right;font-family:'JetBrains Mono';font-size:10px">${c.valor>0?fR$(c.valor):'—'}</td><td style="max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:10px;color:var(--t3)">${prods}</td><td style="text-align:right;font-weight:700;color:${c.dias>90?'var(--red)':c.dias>60?'var(--amber)':'var(--blue)'}">${c.dias}d</td></tr>`;
  });

  h+=`</tbody></table></div></div>`;
  return h;
}

