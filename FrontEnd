  h+=`</div>`;
  if(pAll.length>=1){
    h+=`<div class="chart-card" style="margin-bottom:10px"><div class="chart-title">🏭 Caixas vs Meta</div><canvas id="chProgCx" style="width:100%;height:150px"></canvas></div>`;
