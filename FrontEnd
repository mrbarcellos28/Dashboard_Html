  const curResumo=DATA.resumoMensal.find(x=>x.mes===mesNome);
  // Margem real vem do Aplicativo (calcMargemComercialReal_); Base-faturamento tem impostos zerados
  const _mcrG=(DATA.margemComercialReal&&DATA.margemComercialReal.porMes&&DATA.margemComercialReal.porMes[mesNome])||null;
  const margemPct=_mcrG?_mcrG.margemPct:(curResumo&&curResumo.faturamento>0?curResumo.custos/curResumo.faturamento:0);
  const margemAbs=_mcrG?_mcrG.margem:(curResumo?curResumo.custos:0);
  const fsMes=(DATA.freteSavingMensal&&DATA.freteSavingMensal[mesNome])||{};
