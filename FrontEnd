    h+=`<div class="charts-row"><div class="chart-card"><div class="chart-title">Frete % Faturamento</div><canvas id="chFretePct" class="ccv"></canvas></div><div class="chart-card"><div class="chart-title">Saving %</div><canvas id="chSavingPct" class="ccv"></canvas></div></div>`;
  }

  // ─── RUPTURA DE ESTOQUE ──────────────────────────────────────────────────
