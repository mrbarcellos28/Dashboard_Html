<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pro Water Company</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#07070c;--bg2:#0d0d14;--bg3:#13131e;--bg4:#1a1a28;
  --brd:#1c1c2e;--brd2:#272740;
  --t1:#eaeaf2;--t2:#9898b0;--t3:#5c5c78;
  --green:#22c55e;--green-d:rgba(34,197,94,.12);
  --red:#ef4444;--red-d:rgba(239,68,68,.1);
  --amber:#f59e0b;--amber-d:rgba(245,158,11,.1);
  --blue:#3b82f6;--blue-d:rgba(59,130,246,.12);
  --purple:#a78bfa;--purple-d:rgba(167,139,250,.12);
  --cyan:#06b6d4;--cyan-d:rgba(6,182,212,.12);
  --yellow:#eab308;--yellow-d:rgba(234,179,8,.12);
  --orange:#f97316;--orange-d:rgba(249,115,22,.12);
  --r:10px;--rs:6px;
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t1);height:100vh;overflow:hidden;-webkit-font-smoothing:antialiased}
.mono{font-family:'JetBrains Mono',monospace}
.topbar{height:48px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;background:var(--bg2);border-bottom:1px solid var(--brd);position:relative;z-index:100}
.topbar-left{display:flex;align-items:center;gap:12px}
.logo{width:28px;height:28px;border-radius:6px;background:linear-gradient(135deg,var(--blue),var(--purple));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;color:#fff}
.brand{font-size:14px;font-weight:600;letter-spacing:-.3px}
.topbar-center{display:flex;gap:2px;background:var(--bg3);border-radius:var(--r);padding:3px;border:1px solid var(--brd)}
.tab-btn{padding:6px 16px;border-radius:7px;font-size:11.5px;font-weight:500;color:var(--t3);cursor:pointer;border:none;background:transparent;font-family:'DM Sans';transition:all .2s;white-space:nowrap}
.tab-btn:hover{color:var(--t2)}
.tab-btn.active{color:#fff;box-shadow:0 1px 4px rgba(0,0,0,.3)}
.tab-btn.active[data-tab="geral"]{background:var(--bg)}
.tab-btn.active[data-tab="vendas"]{background:var(--blue)}
.tab-btn.active[data-tab="logistica"]{background:#7c3aed}
.tab-btn.active[data-tab="producao"]{background:#8B6239}
.tab-btn.active[data-tab="suprimentos"]{background:var(--orange)}
.topbar-right{display:flex;align-items:center;gap:8px}
.mode-btn{padding:5px 12px;border-radius:var(--rs);font-size:10.5px;font-weight:500;border:1px solid var(--brd);background:transparent;color:var(--t3);cursor:pointer;font-family:'DM Sans';transition:all .2s}
.mode-btn:hover{border-color:var(--t3);color:var(--t2)}
.mode-btn.on{background:var(--green-d);border-color:var(--green);color:var(--green)}
.clock{font-size:11px;color:var(--t3);font-family:'JetBrains Mono';min-width:50px;text-align:right}
.content{height:calc(100vh - 48px);padding:12px 20px 14px;position:relative;transition:background .5s}
.content.sec-geral{overflow:hidden;background:var(--bg)}
.content.sec-vendas,.content.sec-logistica,.content.sec-producao,.content.sec-suprimentos,.content.sec-diretoria{overflow-y:auto}
.content.sec-vendas{background:linear-gradient(180deg,rgba(59,130,246,.04) 0%,var(--bg) 40%)}
.content.sec-logistica{background:linear-gradient(180deg,rgba(124,58,237,.04) 0%,var(--bg) 40%)}
.content.sec-producao{background:linear-gradient(180deg,rgba(139,98,57,.06) 0%,var(--bg) 40%)}
.content.sec-suprimentos{background:linear-gradient(180deg,rgba(249,115,22,.04) 0%,var(--bg) 40%)}
.content.sec-diretoria{background:linear-gradient(180deg,rgba(167,139,250,.04) 0%,var(--bg) 40%)}
.sec-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.sec-tag{display:inline-flex;align-items:center;gap:8px;padding:6px 16px;border-radius:var(--r);font-size:13px;font-weight:700;letter-spacing:.3px}
.sec-tag.vendas{background:var(--blue-d);color:var(--blue);border:1px solid rgba(59,130,246,.2)}
.sec-tag.logistica{background:var(--purple-d);color:var(--purple);border:1px solid rgba(124,58,237,.2)}
.sec-tag.producao{background:rgba(139,98,57,.15);color:#C8915A;border:1px solid rgba(139,98,57,.25)}
.sec-tag.suprimentos{background:var(--orange-d);color:var(--orange);border:1px solid rgba(249,115,22,.2)}
.sec-tag.geral{background:rgba(255,255,255,.05);color:var(--t1);border:1px solid var(--brd)}
.pf-bar{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.pf-select{background:var(--bg3);border:1px solid var(--brd);border-radius:var(--rs);padding:5px 10px;color:var(--t1);font-family:'DM Sans';font-size:11px;cursor:pointer;outline:none}
.pf-select:hover{border-color:var(--t3)}
.pf-label{font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.4px}
.card-grid{display:grid;gap:10px;margin-bottom:10px}
.card{background:var(--bg2);border:1px solid var(--brd);border-radius:var(--r);padding:16px 18px;position:relative;overflow:hidden}
.card.compact{padding:10px 14px}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.card.a-blue::before{background:var(--blue)}.card.a-purple::before{background:var(--purple)}.card.a-green::before{background:var(--green)}.card.a-orange::before{background:var(--orange)}.card.a-red::before{background:var(--red)}
.card-label{font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px}
.card-duo{display:flex;align-items:baseline;gap:12px}
.card-pct{font-size:22px;font-weight:800;letter-spacing:-.5px;color:var(--t2)}
.card-abs{font-size:36px;font-weight:800;letter-spacing:-1.5px}
.card-meta{display:flex;align-items:center;gap:8px;margin-top:8px}
.card-meta-label{font-size:13px;color:#fff;font-weight:500}
.card-gap{display:flex;align-items:baseline;gap:8px;margin-top:4px}
.card-gap-pct{font-size:16px;font-weight:700;color:var(--t2)}
.card-gap-abs{font-size:20px;font-weight:700}
.card-sub{font-size:12px;color:var(--t3);margin-top:4px}
.kprog{margin-top:8px;height:4px;border-radius:2px;background:rgba(255,255,255,.04);overflow:hidden}
.kprog-fill{height:100%;border-radius:2px;transition:width .7s}
.badge-ok{padding:3px 10px;border-radius:4px;font-size:12px;font-weight:700}
.badge-green{background:rgba(34,197,94,.12);color:var(--green)}
.badge-red{background:rgba(239,68,68,.1);color:var(--red)}
.charts-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.chart-card{background:var(--bg2);border:1px solid var(--brd);border-radius:var(--r);padding:12px 14px}
.chart-title{font-size:11px;font-weight:500;color:var(--t2);margin-bottom:8px}
canvas.ccv{width:100%;height:150px}
.cli-filter{position:relative}
.cli-btn{background:var(--bg3);border:1px solid var(--brd);border-radius:var(--rs);padding:5px 12px;color:var(--t2);font-size:11px;font-family:'DM Sans';cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:5px}
.cli-btn:hover{border-color:var(--blue);color:var(--t1)}
.cli-btn.on{border-color:var(--blue);color:var(--blue);background:var(--blue-d)}
.cli-x{width:14px;height:14px;border-radius:50%;background:rgba(255,255,255,.08);display:inline-flex;align-items:center;justify-content:center;font-size:8px;cursor:pointer}
.cli-dd{position:absolute;top:100%;right:0;margin-top:5px;background:var(--bg3);border:1px solid var(--brd);border-radius:var(--r);width:320px;max-height:380px;box-shadow:0 14px 44px rgba(0,0,0,.6);z-index:50;display:none;flex-direction:column;overflow:hidden}
.cli-dd.open{display:flex}
.cli-dd .search{padding:8px;border-bottom:1px solid var(--brd)}
.cli-dd .search input{width:100%;background:var(--bg);border:1px solid var(--brd);border-radius:var(--rs);padding:7px 10px;color:var(--t1);font-family:'DM Sans';font-size:11px;outline:none}
.cli-dd .list{overflow-y:auto;flex:1;padding:4px}
.cli-item{padding:6px 10px;border-radius:var(--rs);font-size:11px;color:var(--t2);cursor:pointer;transition:all .15s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cli-item:hover{background:var(--bg4);color:var(--t1)}
.tbl-wrap{background:var(--bg2);border:1px solid var(--brd);border-radius:var(--r);overflow:hidden;margin-bottom:10px}
.tbl-head{padding:8px 14px;border-bottom:1px solid var(--brd);display:flex;align-items:center;justify-content:space-between}
.tbl-title{font-size:12px;font-weight:600}
.tbl-count{font-size:10px;color:var(--t3)}
.tbl-body{max-height:400px;overflow-y:auto}
table{width:100%;border-collapse:collapse}
th{text-align:left;padding:6px 12px;font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;font-weight:500;border-bottom:1px solid var(--brd);background:var(--bg3);position:sticky;top:0;z-index:1}
td{padding:5px 12px;font-size:11px;color:var(--t2);border-bottom:1px solid rgba(255,255,255,.02)}
.status-tag{padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600;display:inline-block}
.status-urgente{background:rgba(239,68,68,.15);color:#ef4444}
.status-alerta{background:rgba(245,158,11,.15);color:#f59e0b}
.status-followup{background:rgba(59,130,246,.15);color:#3b82f6}
.status-ativo{background:rgba(34,197,94,.12);color:#22c55e}
.carousel-bar{position:fixed;top:44px;left:0;right:0;height:3px;background:rgba(255,255,255,.03);z-index:200}
.carousel-fill{height:100%;background:var(--green);transition:width linear}
.alert-banner{background:var(--amber-d);border:1px solid rgba(245,158,11,.2);border-radius:var(--r);padding:6px 12px;margin-bottom:8px;display:flex;align-items:center;gap:6px;font-size:11px;color:var(--amber)}
@media(max-width:900px){.card-grid{grid-template-columns:1fr 1fr!important}}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--brd2);border-radius:3px}
</style>
</head>
<body>
<div class="topbar">
  <div class="topbar-left"><div class="logo">PW</div><span class="brand">Pro Water Company</span></div>
  <div class="topbar-center" id="tabBar"></div>
  <div class="topbar-right">
    <button class="mode-btn" id="btnCarousel" onclick="toggleCarousel()">▶ Carrossel</button>
    <span class="clock" id="clock"></span>
  </div>
</div>
<div class="content" id="content"></div>
<div class="carousel-bar" id="carBar" style="display:none"><div class="carousel-fill" id="carFill"></div></div>

<script>
const _RAW = __DATA_PLACEHOLDER__;
const DATA = Object.assign({
  resumoMensal:[],margemCliente:{},margemProduto:{},pedidosMes:[],
  clientes30d:[],meta30d:{totalClientes:0,clientesSemCompra:0},
  producao:[],positivacaoMensal:{},fretePorMes:{},ultimaCompraValor:{},
  ticketMedioPedidos:{},freteSavingMensal:{},vendasDiario:{},logisticaDiario:{},
  pagamentosCarreg:[],otifLogistica:null,otifMensal:null,clientesEmRisco:[],
  churnMensal:null,metaAnual:40000000,
  saldoPallets:{porCliente:[],porMotorista:[],resumo:{totalRetirados:0,totalDevolvidos:0,saldoPendente:0,numClientes:0}},
  palletsMRP:{dias:[],resumo:{}},palletsPorMes:{},
  clientesAtivos:{resumo:{ativos:0,alerta:0,perdidos:0,inativos:0,total12m:0},clientes:[]},
  clientesSemCompra:{sem30d:0,sem60d:0,sem90d:0,totalClientes:0},
  margemComercialReal:{porMes:{},meta12Pct:{}},
  margemComercialMeta:{},
  entradaCaixa:{diario:{},mensal:{}}
}, _RAW||{});

const TABS=[
  {id:'geral',label:'Geral',cls:'geral'},
  {id:'vendas',label:'Vendas',cls:'vendas'},
  {id:'logistica',label:'Logística',cls:'logistica'},
  {id:'producao',label:'Produção',cls:'producao'},
  {id:'suprimentos',label:'Suprimentos',cls:'suprimentos'},
  {id:'diretoria',label:'🔒 Diretoria',cls:'diretoria'}
];

let state={tab:'geral',client:null,ddOpen:false,carousel:false,carTimer:null,carStart:0,carAF:null,carCurrentInterval:20000,scrollTimer:null,scrollDelay:null,dirAuth:false,dirMes:null,filterMes:'atual',filterAno:'atual'};
const CAR_INTERVAL_SHORT=20000;const CAR_INTERVAL_LONG=50000;
const CAR_SCROLL_TABS=["vendas","logistica","diretoria"];
const CAR_TABS=["geral","vendas","logistica","producao","suprimentos"];
function getCarInterval(tab){return CAR_SCROLL_TABS.indexOf(tab)>=0?CAR_INTERVAL_LONG:CAR_INTERVAL_SHORT}

// ═══ HELPERS ═══
const MESES_ORD=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
function sortMeses(arr){return arr.slice().sort((a,b)=>{const[ma,ya]=a.split('/');const[mb,yb]=b.split('/');return(parseInt(ya)*100+MESES_ORD.indexOf(ma))-(parseInt(yb)*100+MESES_ORD.indexOf(mb))})}
function fmt(n,d=0){if(n==null||isNaN(n))return'—';return n.toLocaleString('pt-BR',{minimumFractionDigits:d,maximumFractionDigits:d})}
function fR$(n){if(n==null||isNaN(n))return'R$ —';return'R$ '+fmt(n,2)}
function fR$c(n){if(n==null||isNaN(n))return'R$ —';return n>=1e6?'R$ '+(n/1e6).toFixed(2)+'M':n>=1e3?'R$ '+(n/1e3).toFixed(1)+'k':'R$ '+fmt(n,0)}
function fPct(n){if(n==null||isNaN(n))return'—';return(n*100).toFixed(1).replace('.',',')+'%'}
function getLastDayKey(obj){if(!obj||typeof obj!=='object')return null;const keys=Object.keys(obj);if(!keys.length)return null;const today=new Date().toISOString().slice(0,10);return keys.filter(k=>k<=today).sort().pop()||keys.sort().pop()||null}
function getCurMonth(){
  // Prioridade: margemComercialReal (Base-pedidos-Aplicativo) tem dados mais recentes
  const mcr=DATA.margemComercialReal&&DATA.margemComercialReal.porMes?DATA.margemComercialReal.porMes:{};
  const mcrKeys=sortMeses(Object.keys(mcr));
  const vd=DATA.vendasDiario;
  const vdKeys=vd?sortMeses(Object.keys(vd).map(k=>{const d=new Date(k);return MESES_ORD[d.getMonth()]+'/'+d.getFullYear()}).filter((v,i,a)=>a.indexOf(v)===i)):[];
  // Pegar o mês mais recente entre as duas fontes
  const allMeses=sortMeses([...new Set([...mcrKeys,...vdKeys])]);
  if(allMeses.length) return allMeses[allMeses.length-1];
  const rm=DATA.resumoMensal;if(rm&&rm.length)return rm[rm.length-1].mes;
  return null;
}

function getOtifMes(mesNome){
  if(DATA.otifLogistica&&DATA.otifLogistica.porMes&&DATA.otifLogistica.porMes[mesNome]){
    var d=DATA.otifLogistica.porMes[mesNome];return{otifPct:d.otifPct||0,tempoMedioH:d.leadTimeMedio||0,perfeitas:d.entregues||0,total:d.totalCargas||0,avarias:0,falhas:d.canceladas||0}}
  if(DATA.otifMensal&&DATA.otifMensal[mesNome])return DATA.otifMensal[mesNome];
  if(DATA.otifLogistica&&DATA.otifLogistica.resumo){var r=DATA.otifLogistica.resumo;return{otifPct:r.otifGeral||0,tempoMedioH:r.leadTimeMedioGeral||0,perfeitas:r.totalEntregues||0,total:r.totalCriadas||0,avarias:0,falhas:r.totalCanceladas||0}}
  return null}

function calcMetaMesDinamica(mesNome){
  const metaAnual=DATA.metaAnual||40000000;if(!mesNome)return metaAnual/12;
  const mesNum=MESES_ORD.indexOf(mesNome.split('/')[0])+1;const anoNum=parseInt(mesNome.split('/')[1]);
  let fatAcumAnterior=0;
  if(DATA.resumoMensal&&DATA.resumoMensal.length){DATA.resumoMensal.forEach(function(rm){const parts=rm.mes.split('/');const mNum=MESES_ORD.indexOf(parts[0])+1;const aNum=parseInt(parts[1]);if(aNum===anoNum&&mNum<mesNum)fatAcumAnterior+=rm.faturamento||0})}
  const mesesRestantes=13-mesNum;const metaRestante=metaAnual-fatAcumAnterior;
  return mesesRestantes>0?metaRestante/mesesRestantes:metaAnual/12}

// ═══ PERIOD FILTER ═══
function getAllMesesFromData(){var meses=new Set();DATA.resumoMensal.forEach(function(m){meses.add(m.mes)});if(DATA.freteSavingMensal)Object.keys(DATA.freteSavingMensal).forEach(function(m){meses.add(m)});DATA.producao.forEach(function(p){meses.add(p.mes)});return sortMeses([...meses])}
function getAllAnosFromData(){var anos=new Set();getAllMesesFromData().forEach(function(m){anos.add(m.split('/')[1])});return[...anos].sort()}
function filterMesByPeriod(mesName){var parts=mesName.split('/');var curParts=(getCurMonth()||'Fev/2026').split('/');var mesOk=state.filterMes==='atual'?parts[0]===curParts[0]:state.filterMes==='todos'?true:parts[0]===state.filterMes;var anoOk=state.filterAno==='atual'?parts[1]===curParts[1]:state.filterAno==='todos'?true:parts[1]===state.filterAno;return mesOk&&anoOk}
function filterResumoMensal(){return DATA.resumoMensal.filter(x=>filterMesByPeriod(x.mes))}
function filterProducao(){return DATA.producao.filter(x=>filterMesByPeriod(x.mes))}
function filterFreteMeses(){return sortMeses(Object.keys(DATA.freteSavingMensal||{}).filter(m=>filterMesByPeriod(m)))}
function filterResumoForCharts(){var curParts=(getCurMonth()||'Fev/2026').split('/');var ano=state.filterAno==='atual'?curParts[1]:state.filterAno;return DATA.resumoMensal.filter(function(x){var parts=x.mes.split('/');if(state.filterMes!=='atual'&&state.filterMes!=='todos')return filterMesByPeriod(x.mes);if(ano==='todos')return true;return parts[1]===ano})}
function filterFreteForCharts(){var curParts=(getCurMonth()||'Fev/2026').split('/');var ano=state.filterAno==='atual'?curParts[1]:state.filterAno;return sortMeses(Object.keys(DATA.freteSavingMensal||{}).filter(function(m){var parts=m.split('/');if(state.filterMes!=='atual'&&state.filterMes!=='todos')return filterMesByPeriod(m);if(ano==='todos')return true;return parts[1]===ano}))}
function filterProducaoForCharts(){var curParts=(getCurMonth()||'Fev/2026').split('/');var ano=state.filterAno==='atual'?curParts[1]:state.filterAno;return DATA.producao.filter(function(x){var parts=x.mes.split('/');if(state.filterMes!=='atual'&&state.filterMes!=='todos')return filterMesByPeriod(x.mes);if(ano==='todos')return true;return parts[1]===ano})}
function renderPeriodFilter(){var cur=getCurMonth();var curParts=cur?cur.split('/'):['Fev','2026'];var anos=getAllAnosFromData();var h='<div class="pf-bar"><span class="pf-label">Período:</span><select class="pf-select" onchange="state.filterMes=this.value;render()"><option value="atual"'+(state.filterMes==='atual'?' selected':'')+'>Mês Atual ('+curParts[0]+')</option><option value="todos"'+(state.filterMes==='todos'?' selected':'')+'>Todos os Meses</option>';MESES_ORD.forEach(function(m){h+='<option value="'+m+'"'+(state.filterMes===m?' selected':'')+'>'+m+'</option>'});h+='</select><select class="pf-select" onchange="state.filterAno=this.value;render()"><option value="atual"'+(state.filterAno==='atual'?' selected':'')+'>Ano Atual ('+curParts[1]+')</option><option value="todos"'+(state.filterAno==='todos'?' selected':'')+'>Todos os Anos</option>';anos.forEach(function(a){h+='<option value="'+a+'"'+(state.filterAno===a?' selected':'')+'>'+a+'</option>'});h+='</select></div>';return h}

// ═══ TABS ═══
function initTabs(){document.getElementById('tabBar').innerHTML=TABS.map(t=>`<button class="tab-btn${state.tab===t.id?' active':''}" data-tab="${t.id}" onclick="switchTab('${t.id}')">${t.label}</button>`).join('')}
function switchTab(id){
  if(id==='diretoria'&&!state.dirAuth){var pw=prompt('🔒 Senha:');if(pw==='pro123'){state.dirAuth=true}else{if(pw!==null)alert('Incorreta.');return}}
  stopAutoScroll();state.tab=id;state.client=null;state.ddOpen=false;state.filterMes='atual';state.filterAno='atual';initTabs();render();
  if(state.carousel){state.carCurrentInterval=getCarInterval(state.tab);state.carStart=Date.now();startAutoScroll();scheduleNextTab()}}
function render(){
  const c=document.getElementById('content');c.className='content sec-'+TABS.find(t=>t.id===state.tab).cls;
  try{switch(state.tab){case'geral':c.innerHTML=renderGeral();break;case'vendas':c.innerHTML=renderVendas();break;case'logistica':c.innerHTML=renderLogistica();break;case'producao':c.innerHTML=renderProducao();break;case'suprimentos':c.innerHTML=renderSuprimentos();break;case'diretoria':c.innerHTML=renderDiretoria();break}}
  catch(e){c.innerHTML='<div class="alert-banner" style="margin:20px">⚠️ Erro ao renderizar: '+e.message+'<br><pre style="font-size:9px;margin-top:6px;color:var(--t3)">'+e.stack+'</pre></div>'}
  setTimeout(()=>{try{drawCharts()}catch(e){console.error('Chart error:',e)}},50);
  if(state.ddOpen)popClients('')}

// ═══ CAROUSEL ═══
