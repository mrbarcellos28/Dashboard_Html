function startAutoScroll(){stopAutoScroll();state.scrollDelay=setTimeout(function(){var content=document.getElementById('content');if(!content)return;var maxScroll=content.scrollHeight-content.clientHeight;if(maxScroll<=5)return;var elapsed=Date.now()-state.carStart;var remaining=(state.carCurrentInterval-elapsed)*0.85;var msPerPx=Math.max(remaining/maxScroll,15);state.scrollTimer=setInterval(function(){var c=document.getElementById('content');if(!c||!state.carousel){stopAutoScroll();return}if(c.scrollTop<c.scrollHeight-c.clientHeight)c.scrollTop+=1;else clearInterval(state.scrollTimer)},msPerPx)},3000)}
function stopAutoScroll(){clearTimeout(state.scrollDelay);clearInterval(state.scrollTimer)}
